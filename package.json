{
	"name": "@rodavel/mail-catcher",
	"version": "0.2.0",
	"description": "Serverless email catch-all service built on AWS SES, S3, and DynamoDB",
	"type": "module",
	"license": "MIT",
	"keywords": [
		"ses",
		"email",
		"catch-all",
		"aws",
		"serverless",
		"sst"
	],
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"provision": "bun run scripts/provision.ts",
		"deploy:dev": "npx sst deploy --stage dev",
		"deploy:prod": "npx sst deploy --stage prod",
		"dev": "npx sst dev --stage dev",
		"remove:dev": "npx sst remove --stage dev",
		"test": "bun test --preload ./test-preload.ts apps/ packages/",
		"test:e2e": "bun test e2e/tests/",
		"lint": "biome check --fix"
	},
	"dependencies": {
		"@rodavel/mail-catcher-infra": "workspace:*"
	},
	"devDependencies": {
		"@aws-sdk/client-dynamodb": "^3.1007.0",
		"@aws-sdk/lib-dynamodb": "^3.1007.0",
		"@pulumi/aws": "^7.23.0",
		"@pulumi/pulumi": "^3.225.1",
		"@types/bun": "latest",
		"sst": "^4.2.0",
		"typescript": "^5.7.0"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/RodPaDev/mail-catcher.git"
	},
	"bugs": {
		"url": "https://github.com/RodPaDev/mail-catcher/issues"
	},
	"homepage": "https://github.com/RodPaDev/mail-catcher#readme",
	"workspaces": [
		"apps/*",
		"packages/*",
		"e2e"
	]
}
