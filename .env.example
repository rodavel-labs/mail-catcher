# AWS
AWS_PROFILE=default
AWS_REGION=us-east-1

# SES
SES_DOMAIN=receive.yourdomain.com

# Optional: set to manage DNS via Route 53. Omit to manage DNS externally.
# HOSTED_ZONE_ID=

# Optional: custom domain for the API (e.g., api.inbox.yourdomain.com).
# With HOSTED_ZONE_ID: DNS and certificate are configured automatically.
# Without HOSTED_ZONE_ID: requires a pre-provisioned ACM certificate (looked up by domain at deploy time).
# API_DOMAIN=

# API (test credentials)
API_KEY_ID=
API_TOKEN=

# E2E (API_URL is optional — falls back to apiUrl in .sst/outputs.json)
# API_URL=
